{
  "version": "2.6.0-beta.1",
  "project": {
    "name": "josemi-anton-resume",
    "type": "astro-ssg",
    "description": "Personal resume and professional landing page",
    "domain": "josemianton.com",
    "repository": "github.com/josemi-anton/josemi-anton-resume"
  },
  "framework": {
    "name": "Astro",
    "version": "5.13.7",
    "output": "static",
    "deployment": "cloudflare-workers"
  },
  "governance": {
    "primary": ".cortex/constitution.md",
    "detailed": ".github/copilot-instructions.md",
    "glossary": ".cortex/glossary.md",
    "validation": ".cortex/validation.json"
  },
  "assetManagement": {
    "enabled": true,
    "provider": "cloudflare-r2",
    "cdnDomain": "cdn.josemianton.com",
    "processor": "lib/assets/",
    "manifest": "public/.asset-manifest.json",
    "sizes": [400, 800, 1200],
    "formats": ["avif", "webp"],
    "qualityTiers": {
      "mobile": 90,
      "tablet": 85,
      "desktop": 80
    }
  },
  "commands": {
    "dev": "pnpm dev",
    "build": "pnpm build",
    "preview": "pnpm preview",
    "typeCheck": "pnpm type-check",
    "lint": "pnpm lint",
    "clean": "pnpm clean",
    "deploy": "npx wrangler deploy",
    "cortexValidate": "pnpm run cortex:validate",
    "cortexStatus": "pnpm run cortex:status",
    "assetsSync": "pnpm run assets:sync",
    "assetsStatus": "pnpm run assets:status",
    "imagesAdd": "pnpm run images:add",
    "devImagesPull": "pnpm run dev:images:pull"
  },
  "validation": {
    "enabled": true,
    "strict": false,
    "rulesFile": ".cortex/validation.json",
    "customChecks": true,
    "preCommitValidation": true
  },
  "security": {
    "envVarsRequired": [
      "CF_ACCOUNT_ID",
      "R2_ACCESS_KEY_ID",
      "R2_SECRET_ACCESS_KEY",
      "R2_BUCKET_NAME"
    ],
    "gitignorePatterns": [
      ".env",
      ".env.local",
      ".env.production",
      "public/.asset-manifest.json",
      ".asset-manifest.json"
    ],
    "noHardcodedSecrets": true,
    "rotateApiKeys": "quarterly"
  },
  "performance": {
    "imageOptimization": true,
    "responsiveSizes": true,
    "lazyLoading": true,
    "cdnDelivery": true,
    "codeSplitting": true,
    "cssMinification": true,
    "jsMinification": true
  },
  "accessibility": {
    "wcagLevel": "AA",
    "altTextRequired": true,
    "semanticHtml": true,
    "keyboardNavigation": true,
    "ariaSupport": true
  },
  "metadata": {
    "createdAt": "2026-01-17",
    "migratedFrom": "standalone-copilot-instructions",
    "cortexVersion": "2.6.0-beta.1",
    "maintainer": "Josemi Anton"
  }
}
